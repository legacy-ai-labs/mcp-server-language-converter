# =============================================================================
# MCP Server Configuration
# Copy this file to .env and customize as needed
# =============================================================================

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcp_server
DATABASE_ECHO=false

# Application Configuration
APP_NAME=MCP Server Language Converter
# APP_VERSION is read from pyproject.toml automatically (override with env var if needed)
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# SSE Transport (HTTP Streaming via Server-Sent Events)
# Endpoints: http://<IP>:8000/sse (General), http://<IP>:8001/sse (COBOL)
HTTP_HOST=::
HTTP_PORT=8000
HTTP_PORT_COBOL=8001
HTTP_STREAMING_ENABLED=true

# Streamable HTTP Transport
# Endpoints: http://<IP>:8002/mcp (General), http://<IP>:8003/mcp (COBOL)
STREAMABLE_HTTP_HOST=::
STREAMABLE_HTTP_PORT=8002
STREAMABLE_HTTP_PORT_COBOL=8003
STREAMABLE_HTTP_ENABLED=true

# Observability & Metrics
# Endpoints: http://<IP>:9090/health, http://<IP>:9090/metrics
ENABLE_METRICS=true
ENABLE_EXECUTION_LOGGING=true
METRICS_RETENTION_DAYS=30
LOG_TOOL_INPUTS=false
LOG_TOOL_OUTPUTS=false
MAX_LATENCY_SAMPLES=1000
METRICS_PORT=9090
